7063585,"name":"cilium","namespace":"kube-system","notes":"\n        You have successfully installed Cilium with Hubble Relay and Hubble UI.\n\nYour release version is 1.18.0.\n\nFor any further help, visit https://docs.cilium.io/en/v1.18/gettinghelp\n","revision":1,"values":"{\"bpf\":{\"tproxy\":true},\"ciliumEndpointSlice\":{\"enabled\":true},\"cluster\":{\"name\":\"kubernetes\"},\"devices\":\"eth+\",\"enableLBIPAM\":true,\"externalIps\":{\"enabled\":true},\"gatewayAPI\":{\"enableAlpn\":true,\"enableAppProtocol\":true,\"enabled\":true,\"gatewayClass\":{\"create\":\"true\"},\"hostNetwork\":{\"enabled\":true}},\"hubble\":{\"enabled\":true,\"relay\":{\"enabled\":true,\"replicas\":1,\"rollOutPods\":false,\"tls\":{\"server\":{\"enabled\":false}},\"tolerations\":[{\"key\":\"CriticalAddonsOnly\",\"operator\":\"Exists\"}]},\"tls\":{\"auto\":{\"enabled\":false,\"method\":\"helm\"},\"enabled\":false},\"ui\":{\"backend\":{\"resources\":{\"limits\":{\"cpu\":\"100m\",\"memory\":\"160Mi\"},\"requests\":{\"cpu\":\"10m\",\"memory\":\"64Mi\"}}},\"enabled\":true,\"frontend\":{\"resources\":{\"limits\":{\"cpu\":\"100m\",\"memory\":\"32Mi\"},\"requests\":{\"cpu\":\"10m\",\"memory\":\"16Mi\"}}},\"rollOutPods\":true,\"standalone\":{\"enabled\":true},\"tolerations\":[{\"key\":\"CriticalAddonsOnly\",\"operator\":\"Exists\"}]}},\"image\":{\"pullPolicy\":\"IfNotPresent\",\"useDigest\":false},\"ipam\":{\"mode\":\"kubernetes\"},\"k8sClientRateLimit\":{\"burst\":150,\"qps\":40},\"k8sServiceHost\":\"pihole-control-plane\",\"k8sServicePort\":6443,\"kubeProxyReplacement\":true,\"l7Proxy\":true,\"loadBalancer\":{\"l7\":{\"backend\":\"envoy\"},\"mode\":\"snat\"},\"nodePort\":{\"enabled\":true},\"nodeinit\":{\"enabled\":true},\"operator\":{\"affinity\":{\"nodeAffinity\":{\"requiredDuringSchedulingIgnoredDuringExecution\":{\"nodeSelectorTerms\":[{\"matchExpressions\":[{\"key\":\"node-role.kubernetes.io/control-plane\",\"operator\":\"Exists\"}]}]}}},\"image\":{\"pullPolicy\":\"IfNotPresent\",\"useDigest\":false},\"replicas\":1,\"rollOutPods\":true},\"resources\":{\"limits\":{\"cpu\":\"1000m\",\"memory\":\"384Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}},\"rollOutCiliumPods\":true,\"routingMode\":\"tunnel\",\"socketLB\":{\"enabled\":true},\"tf\":8081,\"tls\":{\"secretsBackend\":\"k8s\"},\"tunnelProtocol\":\"vxlan\"}","version":"1.18.0"},"name":"cilium","namespace":"kube-system","pass_credentials":false,"postrender":null,"recreate_pods":false,"render_subchart_notes":true,"replace":false,"repository":"https://helm.cilium.io/","repository_ca_file":null,"repository_cert_file":null,"repository_key_file":null,"repository_password":null,"repository_username":null,"reset_values":false,"reuse_values":false,"set":[{"name":"k8sServiceHost","type":"","value":"pihole-control-plane"}],"set_list":null,"set_sensitive":null,"set_wo":null,"set_wo_revision":null,"skip_crds":false,"status":"deployed","timeout":300,"values":["tf: 8081\n\n# Global\nimage:\n  pullPolicy: IfNotPresent\n  useDigest: false\n\ncluster:\n  name: kubernetes\n\ntls:\n  secretsBackend: k8s\n\n# Network\nkubeProxyReplacement: true\nk8sServicePort: 6443\nk8sClientRateLimit:\n  qps: 40\n  burst: 150\n\nipam:\n  mode: kubernetes\n\ntunnelProtocol: vxlan\nroutingMode: tunnel\ndevices: eth+\n\nbpf:\n  # not working on kind\n  #  masquerade: true\n  tproxy: true\n\nnodePort:\n  enabled: true\nexternalIps:\n  enabled: true\nsocketLB:\n  enabled: true\nenableLBIPAM: true\nciliumEndpointSlice:\n  enabled: true\n#l2announcements:\n#  enabled: true\n\nl7Proxy: true\nloadBalancer:\n  mode: snat\n  l7:\n    backend: envoy\n\n# Ingress/Gateway API\ngatewayAPI:\n  enabled: true\n  enableAppProtocol: true\n  enableAlpn: true\n  hostNetwork:\n    enabled: true\n  gatewayClass:\n    create: \"true\"\n#  secretsNamespace:\n#    create: false\n#    sync: true\n\n# NodeInit\nnodeinit:\n  enabled: true\n\n# Agent\nrollOutCiliumPods: true\n\nresources:\n  limits:\n    cpu: 1000m\n    memory: 384Mi\n  requests:\n    cpu: 100m\n    memory: 256Mi\n\n# Operator\noperator:\n  image:\n    pullPolicy: IfNotPresent\n    useDigest: false\n\n  replicas: 1\n  rollOutPods: true\n  affinity:\n    nodeAffinity:\n      requiredDuringSchedulingIgnoredDuringExecution:\n        nodeSelectorTerms:\n          - matchExpressions:\n              - key: node-role.kubernetes.io/control-plane\n                operator: Exists\n\n\n# Hubble\nhubble:\n  enabled: true\n\n  tls:\n    enabled: false\n    auto:\n      enabled: false\n      method: helm\n\n  relay:\n    enabled: true\n    replicas: 1\n    rollOutPods: false\n    tolerations:\n      - key: CriticalAddonsOnly\n        operator: \"Exists\"\n\n    tls:\n      server:\n        enabled: false\n\n  ui:\n    enabled: true\n    rollOutPods: true\n    standalone:\n      enabled: true\n\n    tolerations:\n      - key: CriticalAddonsOnly\n        operator: \"Exists\"\n\n    backend:\n      resources:\n        requests:\n          memory: 64Mi\n          cpu: 10m\n        limits:\n          memory: 160Mi\n          cpu: 100m\n    frontend:\n      resources:\n        requests:\n          memory: 16Mi\n          cpu: 10m\n        limits:\n          memory: 32Mi\n          cpu: 100m\n\n# uninstall\n#cni:\n#  install: false\n#  uninstall: true\n#cleanState: true\n#cleanBpfState: true\n#sleepAfterInit: true\n"],"verify":false,"version":"1.18.0","wait":true,"wait_for_jobs":false},"sensitive_attributes":[[{"type":"get_attr","value":"repository_password"}]],"dependencies":["helm_release.cert_manager_crds","module.helm_gateways.helm_release.crds","module.helm_gateways.helm_release.extra","module.helm_gateways.kubernetes_namespace_v1.gateways"]}]},{"module":"module.helm_cilium","mode":"managed","type":"helm_release","name":"extra","provider":"provider[\"registry.opentofu.org/hashicorp/helm\"]","instances":[{"schema_version":2,"attributes":{"atomic":false,"chart":"extra","cleanup_on_fail":false,"create_namespace":false,"dependency_update":false,"description":null,"dev